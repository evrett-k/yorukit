### Yoru.toml Format Spec

```toml
[project]
name = "MyAwesomeTweak"
id = "com.you.myawesometweak"
version = "1.0.0"
author = "Developer"

[target]
mode = "rootless" # options: rootless, roothide, rootful, cyanide
min_ios = "15.0"
architectures = ["arm64", "arm64e"]

[signing]
entitlements = "entitlements.plist"
adhoc = true

[vphone]
enabled = true
auto_respring = true

```